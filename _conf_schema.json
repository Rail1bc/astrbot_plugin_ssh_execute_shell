{
  "host": {
    "description": "目标服务器地址",
    "hint": "例如 192.168.1.100",
    "type": "string",
    "default": "127.0.0.1"
  },
  "port": {
    "description": "SSH 端口",
    "hint": "默认 22",
    "type": "int",
    "default": 22
  },
  "username": {
    "description": "登录用户名",
    "hint": "例如 root",
    "type": "string",
    "default": "root"
  },
  "auth_type": {
    "description": "认证方式",
    "hint": "key 或 password",
    "type": "string",
    "default": "key"
  },
  "key_path": {
    "description": "密钥文件路径（key 模式）",
    "hint": "例如 /path/to/id_rsa",
    "type": "string",
    "default": ""
  },
  "password": {
    "description": "登录密码（password 模式）",
    "hint": "仅在 auth_type 为 password 时使用",
    "type": "string",
    "default": ""
  },
  "timeout": {
    "description": "命令超时秒数",
    "hint": "默认 30 秒",
    "type": "int",
    "default": 30
  },
  "known_hosts": {
    "description": "known_hosts 文件路径。留空表示跳过 host key 校验（首次连接时推荐）；可设为系统路径（如 /root/.ssh/known_hosts）进行严格校验",
    "hint": "留空 = 跳过校验，或填 /root/.ssh/known_hosts",
    "type": "string",
    "default": ""
  }
}
